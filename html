<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Telegram Earning App</title>
    <!-- MoniTag SDK -->
    <script src='//libtl.com/sdk.js' data-zone='11219923' data-sdk='show_11219923'></script>
    
    <style>
        /* Telegram Dark Theme UI */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #1c1c1c; /* Dark Background */
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        .container {
            text-align: center;
            width: 90%;
            max-width: 400px;
            background: #2c2c2e;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

        .balance-card {
            background: #2481cc; /* Telegram Blue */
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
        }

        .balance-card h2 {
            margin: 0;
            font-size: 14px;
            text-transform: uppercase;
            opacity: 0.9;
        }

        .balance-card #balance {
            font-size: 36px;
            font-weight: bold;
            display: block;
            margin-top: 10px;
        }

        .ad-button {
            background-color: #2481cc;
            color: white;
            border: none;
            padding: 15px 30px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 50px;
            cursor: pointer;
            width: 100%;
            transition: transform 0.2s, background-color 0.2s;
            box-shadow: 0 4px 15px rgba(36, 129, 204, 0.4);
        }

        .ad-button:active {
            transform: scale(0.95);
            background-color: #1c66a0;
        }

        .footer-text {
            margin-top: 20px;
            font-size: 12px;
            color: #888;
        }

        /* Loading animation for button */
        .disabled {
            background-color: #555;
            cursor: not-allowed;
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Balance Display -->
        <div class="balance-card">
            <h2>Total Balance</h2>
            <span id="balance">0</span> Coins
        </div>

        <!-- Earn Button -->
        <button id="adBtn" class="ad-button" onclick="showAd()">Watch Ad & Earn</button>

        <p class="footer-text">Watch a full video ad to earn 10 coins!</p>
    </div>

    <script>
        // ব্যালেন্স লোড করা (LocalStorage থেকে)
        let currentBalance = localStorage.getItem('user_balance') ? parseInt(localStorage.getItem('user_balance')) : 0;
        document.getElementById('balance').innerText = currentBalance;

        function showAd() {
            const btn = document.getElementById('adBtn');
            
            // বাটন সাময়িকভাবে ডিজেবল করা যাতে বারবার ক্লিক না হয়
            btn.disabled = true;
            btn.innerText = "Loading Ad...";

            // MoniTag SDK কল করা
            if (typeof show_11219923 === 'function') {
                show_11219923().then(() => {
                    // বিজ্ঞাপনটি সফলভাবে দেখার পর যা ঘটবে
                    addReward(10);
                    btn.disabled = false;
                    btn.innerText = "Watch Ad & Earn";
                }).catch((error) => {
                    alert("Ad failed to load. Please try again later.");
                    btn.disabled = false;
                    btn.innerText = "Watch Ad & Earn";
                });
            } else {
                /<script src='//libtl.com/sdk.js' data-zone='11219923' data-sdk='show_11219923'></script>/ যদি SDK লোড না হয় (AdBlocker থাকতে পারে)
                alert("Ad SDK not loaded. Check your connection or Ad-Blocker.");
                btn.disabled = false;
                btn.innerText = "Watch Ad & Earn";
            }
        }

        // রিওয়ার্ড যোগ করার ফাংশন
        function addReward(amount) {
            currentBalance += amount;
            document.getElementById('balance').innerText = currentBalance;
            
            // LocalStorage-এ ডাটা সেভ করা
            localStorage.setItem('user_balance', currentBalance);
            
            alert("Congratulations! You earned " + amount + " coins.");
        }
    </script>

</body>
</html>
